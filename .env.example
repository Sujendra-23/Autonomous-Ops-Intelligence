# =============================================================================
# Autonomous Operational Intelligence Layer — Environment Configuration
# Copy this file to `.env` and fill in real values.
# =============================================================================

# ---- Database ----
POSTGRES_USER=aoi
POSTGRES_PASSWORD=aoi
POSTGRES_DB=aoi
POSTGRES_PORT=5432

# ---- Cache / queue ----
REDIS_PORT=6379

# ---- Service ports ----
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ---- LLM Provider ----
# Provider: "openai" or "anthropic". Default = anthropic.
LLM_PROVIDER=anthropic

# Anthropic — Haiku 4.5 is the cost-effective default (~$1/MTok input, ~$5/MTok
# output as of 2026-05). Bump to Sonnet or Opus only if extraction quality
# is insufficient on your transcripts.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (alternative provider; also used for embeddings by default).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic doesn't host embeddings — we use OpenAI for embeddings.
# Set EMBEDDING_PROVIDER=local to use a deterministic offline fallback
# (zero API cost, but no semantic meaning — fine for dev/testing).
EMBEDDING_PROVIDER=openai

# ---- Integrations (optional; leave blank to disable a channel) ----

# Notion
NOTION_API_KEY=
# Parent page or database id where new project pages are created
NOTION_PARENT_PAGE_ID=

# Linear
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# Jira (alternative to Linear)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Slack
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# ---- Monitoring ----
# How often (seconds) the drift monitor runs
MONITOR_INTERVAL_SECONDS=900
# A task is considered overdue this many days after due_date
OVERDUE_GRACE_DAYS=0
# A task is "stalled" after this many days with no status change
STALL_DAYS=7

# ---- Security ----
# Comma-separated origins permitted by CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# API key required to ingest transcripts (leave blank to disable auth)
INGEST_API_KEY=

# ---- App ----
LOG_LEVEL=INFO
ENVIRONMENT=development
